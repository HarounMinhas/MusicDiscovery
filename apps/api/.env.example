# Mode configuration (tokenless | spotify | itunes)
DATA_MODE=tokenless
MARKET=BE
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Spotify credentials (required when DATA_MODE=spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/auth/spotify/callback

# Smart Related feature toggles
SMART_RELATED_ENABLED=true
SMART_RELATED_CACHE_TTL_SECONDS=600
SMART_RELATED_MAX_MEMBERS=8
HTTP_DEFAULT_TIMEOUT_MS=5000
