# Mode configuration (tokenless | spotify | itunes)
DATA_MODE=tokenless
MARKET=BE
PORT=8080
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Spotify credentials (required when DATA_MODE=spotify)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8080/api/auth/spotify/callback
